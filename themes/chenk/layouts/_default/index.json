{{- $pages := where site.RegularPages "Lang" .Lang -}}
{{- $list := slice -}}
{{- range $pages -}}
  {{- $entry := dict
      "title" .Title
      "url" .RelPermalink
      "summary" (.Description | default (.Summary | plainify | truncate 200))
      "tags" (.Params.tags | default (slice))
      "series" (.Params.series | default "")
      "date" (.Date.Format "2006-01-02")
  -}}
  {{- $list = $list | append $entry -}}
{{- end -}}
{{- $list | jsonify -}}

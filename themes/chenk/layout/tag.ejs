<% if (page.tag) { %>
<!-- Tag content page: posts with a specific tag -->
<div class="tag-content-page">
  <div class="tag-header">
    <h1 class="page-title">#<%= page.tag %></h1>
    <p class="page-subtitle"><%= page.posts.length %> post<%= page.posts.length !== 1 ? 's' : '' %> tagged with "<%= page.tag %>"</p>
  </div>

  <div class="post-list">
    <% page.posts.sort('date', -1).each(function(post) { %>
    <article class="post-card" data-post-lang="<%= post.lang || 'en' %>">
      <div class="post-card-content">
        <div class="post-card-meta">
          <time datetime="<%= date(post.date, 'YYYY-MM-DD') %>"><%= date(post.date, 'MMM DD, YYYY') %></time>
          <% if (post.categories && post.categories.length) { %>
            <span class="post-card-category"><%= post.categories.data[0].name %></span>
          <% } %>
          <% if (post.lang) { %>
            <span class="post-card-lang"><%= post.lang === 'zh-CN' ? 'CN' : 'EN' %></span>
          <% } %>
        </div>
        <h3 class="post-card-title">
          <a href="<%= url_for(post.path) %>"><%= post.title %></a>
        </h3>
        <p class="post-card-excerpt"><%= post.description || truncate(strip_html(post.content), {length: 200}) %></p>
      </div>
    </article>
    <% }) %>
  </div>

  <%- partial('_partial/pagination') %>
</div>

<% } else { %>
<!-- Tag index page: tag cloud -->
<div class="tag-page">
  <h1 class="page-title">Tags</h1>
  <p class="page-subtitle"><%= site.tags.length %> tags</p>
  <div class="tag-cloud">
    <% site.tags.sort('name').each(function(tag) { %>
    <a href="<%= url_for(tag.path) %>" class="tag-cloud-item" style="font-size: <%= 0.8 + (tag.length / site.posts.length) * 2 %>rem">
      #<%= tag.name %><sup><%= tag.length %></sup>
    </a>
    <% }) %>
  </div>
</div>
<% } %>

<div class="series-index-page">
  <h1 class="page-title" data-i18n="series.title">All Series</h1>
  <p class="page-subtitle"><%= Object.keys(theme.series || {}).length %> <span data-i18n="series.subtitle.suffix">ongoing series covering ML, math, and CS</span></p>

  <%
    // Build series index: count posts by series_key, prefer EN
    var seriesCounts = {};
    var seriesFirst = {};
    site.posts.each(function(p) {
      // Determine series key: prefer string `series:`, then series.slug/key, else infer from path
      var key = null;
      if (typeof p.series === 'string') key = p.series;
      else if (p.series && typeof p.series === 'object') key = p.series.slug || p.series.key || null;
      if (!key && p.source) {
        var m = String(p.source).match(/_posts\/(?:en|zh)\/([^/]+)\//);
        if (m) key = m[1];
      }
      if (!key) return;
      var lang = (p.lang || 'en').toLowerCase();
      // Count once per (key, series_order) — use EN as the canonical counter
      if (!seriesCounts[key]) seriesCounts[key] = { en: 0, zh: 0, orders: {} };
      var ord = p.series_order != null ? p.series_order :
                (p.series && p.series.part != null ? p.series.part : null);
      if (ord != null) seriesCounts[key].orders[ord] = true;
      if (lang.indexOf('zh') === 0) seriesCounts[key].zh++;
      else seriesCounts[key].en++;
      // Track first article per series (lowest order, EN preferred)
      if (lang === 'en') {
        if (!seriesFirst[key] || (ord != null && ord < (seriesFirst[key].order || 999))) {
          seriesFirst[key] = { post: p, order: ord || 1 };
        }
      } else if (!seriesFirst[key]) {
        seriesFirst[key] = { post: p, order: ord || 1 };
      }
    });
  %>

  <% if (theme.series) { %>
    <% for (var key in theme.series) { var s = theme.series[key];
        var info = seriesCounts[key] || { en: 0, zh: 0, orders: {} };
        var published = Object.keys(info.orders).length;  // unique parts published
        var total = s.total || published;
        var progress = total > 0 ? Math.round((published / total) * 100) : 0;
        var firstPost = seriesFirst[key];
        var href = firstPost && firstPost.post ? url_for(firstPost.post.path) : ('/categories/' + s.name.replace(/ /g, '-') + '/');
    %>
      <a href="<%= href %>" class="series-index-card">
        <div class="series-index-card-top">
          <span class="series-index-card-name"><%= s.name %></span>
          <span class="series-index-card-count"><%= published %> / <%= total %></span>
        </div>
        <p class="series-index-card-desc"><%= s.description %></p>
        <div class="series-index-progress">
          <div class="series-index-progress-bar">
            <div class="series-index-progress-fill" style="width: <%= progress %>%"></div>
          </div>
          <span class="series-index-progress-text"><%= progress %>%</span>
        </div>
      </a>
    <% } %>
  <% } %>
</div>

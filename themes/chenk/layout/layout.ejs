<!DOCTYPE html>
<%
  var pageLang = page.lang || (config.language && (Array.isArray(config.language) ? config.language[0] : config.language)) || 'en';
  var translationUrl = '';
  try { translationUrl = (typeof translation_url === 'function') ? (translation_url(page) || '') : ''; } catch (e) { translationUrl = ''; }
%>
<html lang="<%= pageLang %>" data-theme="light" data-page-lang="<%= pageLang %>" data-translation="<%= translationUrl %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5">
  <meta name="description" content="<%= page.description ? page.description : (page.excerpt ? strip_html(page.excerpt).substring(0, 160) : theme.base_info.description) %>">
  <meta name="author" content="<%= theme.base_info.author %>">
  <meta name="generator" content="Hexo">
  <title><%= page.title ? page.title + ' | ' + theme.base_info.title : theme.base_info.title %></title>

  <!-- Preload critical fonts -->
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&family=Noto+Sans+SC:wght@400;500;600;700&display=swap" as="style">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&family=Noto+Sans+SC:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- Open Graph -->
  <meta property="og:type" content="<%= is_post() ? 'article' : 'website' %>">
  <meta property="og:title" content="<%= page.title || theme.base_info.title %>">
  <meta property="og:description" content="<%= page.description || strip_html(page.excerpt || '').substring(0, 200) || theme.base_info.description %>">
  <meta property="og:url" content="<%= url_for(page.path || '') %>">
  <meta property="og:site_name" content="<%= theme.base_info.title %>">
  <% if (page.cover) { %>
  <meta property="og:image" content="<%= page.cover %>">
  <% } %>
  <% if (is_post()) { %>
  <meta property="article:published_time" content="<%= date(page.date, 'YYYY-MM-DD') %>">
  <meta property="article:author" content="<%= theme.base_info.author %>">
  <% if (page.categories && page.categories.length) { %>
  <meta property="article:section" content="<%= page.categories.data[0].name %>">
  <% } %>
  <% if (page.tags && page.tags.length) { page.tags.each(function(tag) { %>
  <meta property="article:tag" content="<%= tag.name %>">
  <% }) } %>
  <% } %>

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= page.title || theme.base_info.title %>">
  <meta name="twitter:description" content="<%= page.description || strip_html(page.excerpt || '').substring(0, 200) || theme.base_info.description %>">
  <% if (page.cover) { %>
  <meta name="twitter:image" content="<%= page.cover %>">
  <% } %>

  <!-- Canonical URL -->
  <link rel="canonical" href="<%= theme.base_info.url %><%= url_for(page.path || '') %>">

  <!-- RSS / Atom Feed -->
  <link rel="alternate" href="<%= url_for('atom.xml') %>" title="<%= theme.base_info.title %>" type="application/atom+xml">
  <link rel="alternate" href="<%= url_for('rss2.xml') %>" title="<%= theme.base_info.title %>" type="application/rss+xml">

  <!-- Sitemap -->
  <link rel="sitemap" type="application/xml" href="<%= url_for('sitemap.xml') %>">

  <!-- Favicon -->
  <link rel="shortcut icon" href="<%= theme.style.favicon || '/images/logo.svg' %>">
  <link rel="icon" type="image/svg+xml" href="/images/logo.svg">
  <link rel="apple-touch-icon" href="/images/apple-touch-icon.png">

  <!-- Stylesheets -->
  <%- css('css/main.css') %>
  <%- css('css/article.css') %>
  <%- css('css/code.css') %>

  <% if (theme.features.katex) { %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
  <% } %>

  <% if (is_post()) { %>
  <!-- JSON-LD Structured Data for Article -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "<%= page.title %>",
    "description": "<%= (page.description || strip_html(page.excerpt || '').substring(0, 200) || '').replace(/"/g, '\\"') %>",
    "datePublished": "<%= date(page.date, 'YYYY-MM-DD') %>",
    <% if (page.updated) { %>"dateModified": "<%= date(page.updated, 'YYYY-MM-DD') %>",<% } %>
    "author": {
      "@type": "Person",
      "name": "<%= theme.base_info.author %>",
      "url": "<%= theme.base_info.url %>"
    },
    "publisher": {
      "@type": "Organization",
      "name": "<%= theme.base_info.title %>",
      "url": "<%= theme.base_info.url %>"
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "<%= theme.base_info.url %><%= url_for(page.path) %>"
    },
    "wordCount": "<%= wordcount(page.content) %>"
  }
  </script>
  <% } else { %>
  <!-- JSON-LD Structured Data for Website -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "<%= theme.base_info.title %>",
    "url": "<%= theme.base_info.url %>",
    "description": "<%= theme.base_info.description %>",
    "author": {
      "@type": "Person",
      "name": "<%= theme.base_info.author %>"
    },
    "potentialAction": {
      "@type": "SearchAction",
      "target": "<%= theme.base_info.url %>/?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>
  <% } %>

  <!-- Theme initialization (prevent FOUC) -->
  <script>
    (function(){
      var t = localStorage.getItem('theme');
      if (!t) t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
</head>
<body>
  <%- partial('_partial/header') %>

  <% if (theme.features.reading_progress && is_post()) { %>
  <div class="reading-progress" id="reading-progress"></div>
  <% } %>

  <main class="main-content">
    <%- body %>
  </main>

  <%- partial('_partial/footer') %>

  <%- js('js/main.js') %>

  <% if (theme.features.katex) { %>
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"
    onload="renderMathInElement(document.body, {
      delimiters: [
        {left: '$$', right: '$$', display: true},
        {left: '$', right: '$', display: false}
      ],
      throwOnError: false
    });">
  </script>
  <% } %>

  <% if (theme.features.search) { %>
  <%- js('js/search.js') %>
  <% } %>
</body>
</html>

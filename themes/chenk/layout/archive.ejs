<div class="archive-page">
  <h1 class="page-title">Archives</h1>
  <p class="page-subtitle"><%= site.posts.length %> articles and counting</p>

  <% var years = {}; site.posts.sort('date', -1).each(function(post) { var y = date(post.date, 'YYYY'); if (!years[y]) years[y] = []; years[y].push(post); }); %>

  <% for (var year in years) { %>
  <section class="archive-year">
    <h2 class="archive-year-title">
      <%= year %>
      <span class="archive-year-count"><%= years[year].length %> post<%= years[year].length !== 1 ? 's' : '' %></span>
    </h2>
    <div class="archive-list">
      <% years[year].forEach(function(post) { %>
      <a href="<%= url_for(post.path) %>" class="archive-item">
        <time><%= date(post.date, 'MMM DD') %></time>
        <span class="archive-item-title"><%= post.title %></span>
        <% if (post.lang) { %>
        <span class="archive-item-lang"><%= post.lang === 'zh-CN' ? 'CN' : 'EN' %></span>
        <% } %>
      </a>
      <% }) %>
    </div>
  </section>
  <% } %>
</div>

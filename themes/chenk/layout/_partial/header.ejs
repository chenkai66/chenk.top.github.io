<header class="site-header">
  <div class="header-inner">
    <a href="/" class="site-logo">
      <span class="logo-text"><%= theme.base_info.title %></span>
    </a>

    <nav class="main-nav">
      <% for (var name in theme.menu) { %>
        <a href="<%= theme.menu[name] %>" class="nav-link<%= is_current(theme.menu[name]) ? ' active' : '' %>">
          <%= name %>
        </a>
      <% } %>
    </nav>

    <div class="header-actions">
      <% if (theme.features.language_switcher) { %>
      <button class="lang-switcher" id="lang-switcher" aria-label="Switch language">
        <span class="lang-label" id="lang-label"><%= (config.language || 'en').indexOf('zh') === 0 ? 'CN' : 'EN' %></span>
      </button>
      <% } %>

      <% if (theme.features.dark_mode) { %>
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode">
        <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
        <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
      <% } %>

      <% if (theme.features.search) { %>
      <button class="search-toggle" id="search-toggle" aria-label="Search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      </button>
      <% } %>

      <button class="mobile-menu-toggle" id="mobile-menu-toggle" aria-label="Menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
      </button>
    </div>
  </div>

  <% if (theme.features.search) { %>
  <div class="search-overlay" id="search-overlay">
    <div class="search-container">
      <div style="position: relative;">
        <input type="text" class="search-input" id="search-input" placeholder="Search articles..." autocomplete="off">
        <div class="search-kbd" id="search-kbd-hint">
          <kbd>Esc</kbd>
        </div>
      </div>
      <div class="search-results" id="search-results"></div>
    </div>
  </div>
  <% } %>
</header>

<!-- Mobile Navigation Drawer -->
<div class="mobile-drawer-overlay" id="mobile-drawer-overlay"></div>
<nav class="mobile-drawer" id="mobile-drawer">
  <div class="mobile-drawer-header">
    <span class="mobile-drawer-title"><%= theme.base_info.title %></span>
    <button class="mobile-drawer-close" id="mobile-drawer-close" aria-label="Close menu">&times;</button>
  </div>
  <div class="mobile-drawer-nav">
    <% for (var name in theme.menu) { %>
      <a href="<%= theme.menu[name] %>" class="<%= is_current(theme.menu[name]) ? 'active' : '' %>">
        <%= name %>
      </a>
    <% } %>
  </div>
  <div class="mobile-drawer-actions">
    <% if (theme.features.dark_mode) { %>
    <button id="mobile-theme-toggle" aria-label="Toggle dark mode">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
      Theme
    </button>
    <% } %>
    <% if (theme.features.language_switcher) { %>
    <button id="mobile-lang-switcher" aria-label="Switch language">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
      <span id="mobile-lang-label"><%= (config.language || 'en').indexOf('zh') === 0 ? 'CN' : 'EN' %></span>
    </button>
    <% } %>
  </div>
</nav>

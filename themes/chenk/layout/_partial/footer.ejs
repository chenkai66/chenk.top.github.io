<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-col footer-about">
        <div class="footer-about-title"><%= theme.base_info.title %></div>
        <p class="footer-about-desc">
          <%= theme.base_info.description || 'Deep technical writing on machine learning, mathematics, and computer science — from first principles to production systems.' %>
        </p>
        <div class="footer-social">
          <% if (theme.social && theme.social.github) { %>
          <a href="<%= theme.social.github %>" target="_blank" rel="noopener" aria-label="GitHub">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <% } %>
          <% if (theme.social && theme.social.email) { %>
          <a href="mailto:<%= theme.social.email %>" aria-label="Email">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </a>
          <% } %>
          <a href="/atom.xml" aria-label="RSS Feed" title="RSS Feed">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
          </a>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-col-title" data-i18n="footer.series">Series</div>
        <ul class="footer-links">
          <% if (theme.series) { %>
            <% var sKeys = Object.keys(theme.series).slice(0, 5); %>
            <% sKeys.forEach(function(key) { var s = theme.series[key]; %>
              <li><a href="/categories/<%= s.name.replace(/ /g, '-') %>/"><%= s.name %></a></li>
            <% }); %>
          <% } %>
          <li><a href="/series/" data-i18n="footer.allseries">All series &rarr;</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <div class="footer-col-title" data-i18n="footer.site">Site</div>
        <ul class="footer-links">
          <li><a href="/" data-i18n="nav.home">Home</a></li>
          <li><a href="/series/" data-i18n="nav.series">Series</a></li>
          <li><a href="/projects/" data-i18n="nav.projects">Projects</a></li>
          <li><a href="/archives/" data-i18n="nav.archives">Archives</a></li>
          <li><a href="/about/" data-i18n="nav.about">About</a></li>
          <li><a href="/atom.xml" data-i18n="footer.rss">RSS Feed</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-info">
        <p>&copy; <%= new Date().getFullYear() %> <%= theme.base_info.author %>. <span data-i18n="footer.copyright.suffix">Built with knowledge and curiosity.</span></p>
        <p class="footer-powered"><span data-i18n="footer.powered">Powered by</span> <a href="https://hexo.io" target="_blank" rel="noopener">Hexo</a> &middot; <span data-i18n="footer.theme">Theme</span> <a href="<%= theme.base_info.url %>" rel="noopener">chenk</a></p>
      </div>
    </div>
  </div>
</footer>

<% if (theme.features.back_to_top) { %>
<button class="back-to-top" id="back-to-top" aria-label="Back to top">
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m18 15-6-6-6 6"/></svg>
</button>
<% } %>

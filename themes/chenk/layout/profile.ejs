<div class="profile-page">

  <!-- ============== HERO ============== -->
  <section class="profile-hero">
    <div class="profile-hero-bg" aria-hidden="true">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
      <div class="grid-overlay"></div>
    </div>

    <div class="profile-hero-inner">
      <div class="profile-avatar" aria-hidden="true">
        <span class="profile-avatar-mark">CK</span>
        <span class="profile-avatar-status" title="Currently building"></span>
      </div>

      <h1 class="profile-name">
        <span class="profile-name-en">Chen Kai</span>
        <span class="profile-name-cn">陈锴</span>
      </h1>

      <p class="profile-tagline" data-i18n="me.tagline">
        Engineer · Researcher · Builder of agent systems
      </p>

      <div class="profile-quick-tags">
        <span class="quick-tag">Machine Learning</span>
        <span class="quick-tag">Cloud Infrastructure</span>
        <span class="quick-tag">AI Agents</span>
        <span class="quick-tag">Math First</span>
      </div>

      <div class="profile-cta">
        <a href="#projects" class="btn-primary" data-i18n="me.cta.work">See my work</a>
        <a href="/" class="btn-ghost" data-i18n="me.cta.blog">Read the blog</a>
      </div>

      <div class="profile-socials">
        <a href="https://github.com/chenkai66" target="_blank" rel="noopener" class="social-link" aria-label="GitHub">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.9 1.2 1.9 1.2 1.1 1.9 2.9 1.4 3.6 1 .1-.8.4-1.4.8-1.7-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.4-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.3 2.8.1 3.1.8.8 1.2 1.9 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3"/></svg>
        </a>
        <a href="mailto:chenkai.nb.666@gmail.com" class="social-link" aria-label="Email">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
        </a>
        <a href="https://www.chenk.top/" class="social-link" aria-label="Blog">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============== BIO + STATS ============== -->
  <section class="profile-bio">
    <div class="bio-grid">
      <div class="bio-text">
        <h2 class="section-eyebrow" data-i18n="me.about.eyebrow">About</h2>
        <p class="bio-lead">
          I build systems where <strong>large models meet real users</strong> —
          recommendation pipelines, marketing automation, and the agent infrastructure that makes
          all of it observable, debuggable, and fast.
        </p>
        <p>
          Day-to-day I write production Python and TypeScript, design retrieval and ranking pipelines, and
          run a couple of small servers that quietly do useful things.
          On the side I write long-form technical articles —
          the kind I wish existed when I was learning ML from scratch — and ship them at
          <a href="/">chenk.top</a> in both English and 中文.
        </p>
        <p>
          My current obsession is <strong>autonomous agent systems</strong>: how to make
          long-running LLM workflows that don't drift, can resume after failures, and can
          honestly report what they did.
        </p>
      </div>

      <aside class="bio-stats">
        <h2 class="section-eyebrow" data-i18n="me.bynumbers">By the numbers</h2>
        <div class="bio-stat-row">
          <div class="bio-stat">
            <span class="bio-stat-num" id="bs-articles">375</span>
            <span class="bio-stat-label" data-i18n="me.stats.articles">Articles</span>
          </div>
          <div class="bio-stat">
            <span class="bio-stat-num">14</span>
            <span class="bio-stat-label" data-i18n="me.stats.series">Series</span>
          </div>
          <div class="bio-stat">
            <span class="bio-stat-num">2</span>
            <span class="bio-stat-label" data-i18n="me.stats.languages">Languages</span>
          </div>
          <div class="bio-stat">
            <span class="bio-stat-num">3</span>
            <span class="bio-stat-label" data-i18n="me.stats.systems">Live Systems</span>
          </div>
        </div>
        <p class="bio-stat-note" data-i18n="me.stats.note">
          Numbers update automatically with each generate.
        </p>
      </aside>
    </div>
  </section>

  <!-- ============== PROJECTS ============== -->
  <section class="profile-projects" id="projects">
    <h2 class="section-eyebrow eyebrow-center" data-i18n="me.projects.eyebrow">Projects in production</h2>
    <h3 class="section-title-big" data-i18n="me.projects.title">Things I run, not just things I built</h3>

    <div class="project-grid">

      <!-- AI4Marketing -->
      <article class="project-card project-card-marketing">
        <div class="project-card-glow" aria-hidden="true"></div>
        <div class="project-card-head">
          <div class="project-tags">
            <span class="project-tag tag-live">● Live</span>
            <span class="project-tag">AI · Marketing</span>
          </div>
          <a href="https://llm4marketing.com" target="_blank" rel="noopener" class="project-link" aria-label="Open AI4Marketing">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7M7 7h10v10"/></svg>
          </a>
        </div>
        <h3 class="project-name">AI4Marketing</h3>
        <p class="project-domain">llm4marketing.com</p>
        <p class="project-desc">
          A <strong>marketing automation platform</strong> built on top of an agent runtime.
          Operators chat with a controller; the controller dispatches sub-agents that own
          specific channels — email, ad creative, video generation, voice synthesis —
          and reports back through a unified dashboard.
        </p>
        <div class="project-stack">
          <span class="stack-chip">Qwen3-Max</span>
          <span class="stack-chip">DashScope</span>
          <span class="stack-chip">Wanxiang</span>
          <span class="stack-chip">Qwen-TTS</span>
          <span class="stack-chip">OSS</span>
          <span class="stack-chip">Nginx</span>
        </div>
        <div class="project-metrics">
          <div class="metric">
            <span class="metric-num">11</span>
            <span class="metric-lbl">Alibaba Cloud products</span>
          </div>
          <div class="metric">
            <span class="metric-num">170+</span>
            <span class="metric-lbl">test cases</span>
          </div>
          <div class="metric">
            <span class="metric-num">20</span>
            <span class="metric-lbl">verify modules</span>
          </div>
        </div>
      </article>

      <!-- AI4Science / OpenClaw -->
      <article class="project-card project-card-science">
        <div class="project-card-glow" aria-hidden="true"></div>
        <div class="project-card-head">
          <div class="project-tags">
            <span class="project-tag tag-live">● Live</span>
            <span class="project-tag">AI · Science</span>
          </div>
          <a href="https://github.com/chenkai66" target="_blank" rel="noopener" class="project-link" aria-label="View on GitHub">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7M7 7h10v10"/></svg>
          </a>
        </div>
        <h3 class="project-name">AI4Science <span class="project-name-sub">via OpenClaw</span></h3>
        <p class="project-domain">CK Planet · agent control plane</p>
        <p class="project-desc">
          A <strong>multi-agent control plane</strong> for scientific workflows.
          Hosts long-running research agents that read papers, run experiments, write reports —
          and a real-time dashboard that shows session timelines, rate-limit budgets, and
          token economics across providers (Anthropic, Google, Alibaba).
        </p>
        <div class="project-stack">
          <span class="stack-chip">Claude Code</span>
          <span class="stack-chip">Gemini</span>
          <span class="stack-chip">DingTalk Stream</span>
          <span class="stack-chip">Node 22</span>
          <span class="stack-chip">SQLite</span>
          <span class="stack-chip">SSH gateway</span>
        </div>
        <div class="project-metrics">
          <div class="metric">
            <span class="metric-num">24/7</span>
            <span class="metric-lbl">always-on agents</span>
          </div>
          <div class="metric">
            <span class="metric-num">3</span>
            <span class="metric-lbl">LLM providers</span>
          </div>
          <div class="metric">
            <span class="metric-num">∞</span>
            <span class="metric-lbl">resilience loops</span>
          </div>
        </div>
      </article>

      <!-- chenk.top blog -->
      <article class="project-card project-card-blog">
        <div class="project-card-glow" aria-hidden="true"></div>
        <div class="project-card-head">
          <div class="project-tags">
            <span class="project-tag tag-live">● Live</span>
            <span class="project-tag">Writing · Tooling</span>
          </div>
          <a href="/" class="project-link" aria-label="Open blog">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7M7 7h10v10"/></svg>
          </a>
        </div>
        <h3 class="project-name">chenk.top</h3>
        <p class="project-domain">This blog · custom Hexo theme</p>
        <p class="project-desc">
          A bilingual long-form technical blog with a <strong>custom theme written from scratch</strong>.
          Hand-rolled image pipeline (matplotlib → OSS), KaTeX math, three-column reader layout,
          dark mode, on-device search, and a generator helper that pairs every article to its
          translation.
        </p>
        <div class="project-stack">
          <span class="stack-chip">Hexo</span>
          <span class="stack-chip">EJS</span>
          <span class="stack-chip">KaTeX</span>
          <span class="stack-chip">matplotlib</span>
          <span class="stack-chip">Aliyun OSS</span>
          <span class="stack-chip">GitHub Pages</span>
        </div>
        <div class="project-metrics">
          <div class="metric">
            <span class="metric-num">375</span>
            <span class="metric-lbl">articles (EN+CN)</span>
          </div>
          <div class="metric">
            <span class="metric-num">~1.5k</span>
            <span class="metric-lbl">figures rendered</span>
          </div>
          <div class="metric">
            <span class="metric-num">14</span>
            <span class="metric-lbl">topic series</span>
          </div>
        </div>
      </article>

    </div>

    <p class="project-footer-note">
      All three live on a single $40/mo ECS box. The dashboard at
      <a href="https://llm4marketing.com" target="_blank" rel="noopener">llm4marketing.com</a>
      is the same control plane that serves both — different mounts, different domains.
    </p>
  </section>

  <!-- ============== WRITING ============== -->
  <section class="profile-writing">
    <h2 class="section-eyebrow eyebrow-center" data-i18n="me.recent.eyebrow">Recent writing</h2>
    <h3 class="section-title-big" data-i18n="me.recent.title">From the blog</h3>
    <div class="writing-grid">
      <% var recent = site.posts.sort('date', -1).limit(6); %>
      <% recent.each(function(p) { %>
        <a href="<%= url_for(p.path) %>" class="writing-item" data-post-lang="<%= p.lang || 'en' %>">
          <div class="writing-meta">
            <% if (p.categories && p.categories.length) { %>
              <span class="writing-category"><%= p.categories.data[0].name %></span>
            <% } %>
            <span class="writing-date"><%= date(p.date, 'MMM YYYY') %></span>
          </div>
          <h4 class="writing-title"><%= p.title %></h4>
        </a>
      <% }) %>
    </div>
    <div class="writing-cta">
      <a href="/archives/" class="btn-ghost" data-i18n="me.recent.cta">All articles &rarr;</a>
    </div>
  </section>

  <!-- ============== CONTACT ============== -->
  <section class="profile-contact">
    <div class="contact-card">
      <h2 class="contact-title" data-i18n="me.contact.title">Want to talk?</h2>
      <p class="contact-text" data-i18n="me.contact.text">
        I'm always up for a chat about ML systems, agent infrastructure, or
        long-form technical writing. Drop a line — I read everything.
      </p>
      <div class="contact-actions">
        <a href="mailto:chenkai.nb.666@gmail.com" class="btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
          chenkai.nb.666@gmail.com
        </a>
        <a href="https://github.com/chenkai66" target="_blank" rel="noopener" class="btn-ghost">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.9 1.2 1.9 1.2 1.1 1.9 2.9 1.4 3.6 1 .1-.8.4-1.4.8-1.7-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.4-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.3 2.8.1 3.1.8.8 1.2 1.9 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3"/></svg>
          @chenkai66
        </a>
      </div>
    </div>
  </section>

</div>

<script>
(function(){
  // Set article count from site stats
  var el = document.getElementById('bs-articles');
  if (el && window.__SITE_STATS__ && window.__SITE_STATS__.posts) {
    el.textContent = window.__SITE_STATS__.posts;
  }
})();
</script>

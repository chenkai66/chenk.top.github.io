<% if (page.category) { %>
<!-- Category content page: posts in a specific category -->
<div class="category-content-page">
  <div class="category-header">
    <h1 class="page-title">
      <%= page.category %>
      <span class="category-post-count"><%= page.posts.length %> post<%= page.posts.length !== 1 ? 's' : '' %></span>
    </h1>
    <%
      var seriesInfo = null;
      if (theme.series) {
        for (var key in theme.series) {
          if (theme.series[key].name === page.category) { seriesInfo = theme.series[key]; break; }
        }
      }
    %>
    <% if (seriesInfo) { %>
    <p class="page-subtitle"><%= seriesInfo.description %></p>
    <% } %>
  </div>

  <div class="post-list">
    <% page.posts.sort('date', -1).each(function(post) { %>
    <article class="post-card">
      <div class="post-card-content">
        <div class="post-card-meta">
          <time datetime="<%= date(post.date, 'YYYY-MM-DD') %>"><%= date(post.date, 'MMM DD, YYYY') %></time>
          <% if (post.lang) { %>
            <span class="post-card-lang"><%= post.lang === 'zh-CN' ? 'CN' : 'EN' %></span>
          <% } %>
          <span class="post-card-reading-time"><%= Math.ceil(wordcount(post.content) / 250) %> min read</span>
        </div>
        <h3 class="post-card-title">
          <a href="<%= url_for(post.path) %>"><%= post.title %></a>
        </h3>
        <p class="post-card-excerpt"><%= post.description || truncate(strip_html(post.content), {length: 200}) %></p>
        <% if (post.tags && post.tags.length) { %>
        <div class="post-card-tags">
          <% post.tags.each(function(tag) { %>
            <a href="<%= url_for(tag.path) %>" class="tag"><%= tag.name %></a>
          <% }) %>
        </div>
        <% } %>
      </div>
    </article>
    <% }) %>
  </div>

  <%- partial('_partial/pagination') %>
</div>

<% } else { %>
<!-- Category index page: list of all categories -->
<div class="category-page">
  <h1 class="page-title">Categories</h1>
  <p class="page-subtitle"><%= site.categories.length %> categories</p>
  <div class="category-list">
    <% site.categories.sort('name').each(function(cat) { %>
    <a href="<%= url_for(cat.path) %>" class="category-item">
      <span class="category-name"><%= cat.name %></span>
      <span class="category-count"><%= cat.length %></span>
    </a>
    <% }) %>
  </div>
</div>
<% } %>

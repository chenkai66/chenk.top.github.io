<%
  // A "rich" series object has .name/.part/.total and warrants the left sidebar.
  // String-form series (en posts) do not render the sidebar, so we treat them as no series.
  var hasSeriesSidebar = !!(page.series && typeof page.series === 'object' && page.series.name && page.series.total);
  var hasTocSidebar = !!theme.features.toc;
  var layoutClass = 'article-layout';
  if (hasSeriesSidebar && hasTocSidebar) layoutClass += ' has-both-sidebars';
  else if (hasSeriesSidebar) layoutClass += ' has-series-only';
  else if (hasTocSidebar) layoutClass += ' has-toc-only';
  else layoutClass += ' has-no-sidebar';
%>
<article class="article-page">
  <div class="<%= layoutClass %>">
    <!-- Series Sidebar (left) -->
    <% if (hasSeriesSidebar) { %>
    <aside class="series-sidebar" id="series-sidebar">
      <div class="series-sidebar-inner">
        <h4 class="series-sidebar-title"><%= page.series.name %></h4>
        <p class="series-sidebar-progress">Part <%= page.series.part %> of <%= page.series.total %></p>
        <div class="series-progress-bar">
          <div class="series-progress-fill" style="width: <%= (page.series.part / page.series.total * 100) %>%"></div>
        </div>
        <nav class="series-chapter-list">
          <!-- Series chapters populated by JS or by listing related posts -->
        </nav>
      </div>
    </aside>
    <% } %>

    <!-- Article Content (center) -->
    <div class="article-main">
      <!-- Breadcrumb Navigation -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/" data-i18n="nav.home">Home</a>
        <span class="breadcrumb-separator">&#9656;</span>
        <% if (page.categories && page.categories.length) { %>
          <% var cats = page.categories.toArray(); %>
          <a href="<%= url_for(cats[0].path) %>"><%= cats[0].name %></a>
          <span class="breadcrumb-separator">&#9656;</span>
        <% } %>
        <span class="breadcrumb-current"><%= page.title %></span>
      </nav>

      <header class="article-header">
        <% if (page.categories && page.categories.length) { %>
        <div class="article-category">
          <% page.categories.each(function(cat) { %>
            <a href="<%= url_for(cat.path) %>"><%= cat.name %></a>
          <% }) %>
        </div>
        <% } %>

        <h1 class="article-title"><%= page.title %></h1>

        <div class="article-meta">
          <time datetime="<%= date(page.date, 'YYYY-MM-DD') %>">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            <%= date(page.date, 'MMMM DD, YYYY') %>
          </time>
          <% if (page.updated && page.updated.valueOf() !== page.date.valueOf()) { %>
          <span class="update-time" title="Last updated">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
            Updated <%= date(page.updated, 'MMM DD, YYYY') %>
          </span>
          <% } %>
          <% if (theme.features.reading_time) { %>
          <span class="reading-time" data-auto-reading>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            <span class="rt-num">—</span> <span data-i18n="post.minRead">min read</span>
          </span>
          <% } %>
          <% if (theme.features.word_count) { %>
          <span class="word-count" data-auto-wordcount>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7V4h16v3M9 20h6M12 4v16"/></svg>
            <span class="wc-num">—</span> <span data-i18n="post.words">words</span>
          </span>
          <% } %>
        </div>

        <% if (page.description) { %>
        <p class="article-description"><%= page.description %></p>
        <% } %>
      </header>

      <div class="article-content markdown-body">
        <%- page.content %>
      </div>

      <!-- Series Navigation -->
      <% if (hasSeriesSidebar) { %>
      <nav class="series-nav">
        <div class="series-nav-inner">
          <span class="series-nav-label"><%= page.series.name %> &mdash; Part <%= page.series.part %> of <%= page.series.total %></span>
        </div>
      </nav>
      <% } %>

      <!-- Tags -->
      <% if (page.tags && page.tags.length) { %>
      <div class="article-tags">
        <% page.tags.each(function(tag) { %>
          <a href="<%= url_for(tag.path) %>" class="tag">#<%= tag.name %></a>
        <% }) %>
      </div>
      <% } %>

      <!-- Post Navigation -->
      <%
        // Prefer same-series, same-language neighbors. If none, fall back to
        // hexo's chronological prev/next BUT only when same language.
        var nav = (typeof series_neighbors === 'function') ? series_neighbors(page) : { prev: null, next: null };
        var prevPost = nav.prev;
        var nextPost = nav.next;
        var pageLang = (page.lang || '').toLowerCase();
        function sameLang(p) {
          if (!p) return false;
          var pl = (p.lang || '').toLowerCase();
          // 'zh-CN' vs 'zh' tolerated, both start with 'zh'
          if (pageLang.indexOf('zh') === 0) return pl.indexOf('zh') === 0;
          return pl === 'en' || pl === '';
        }
        if (!prevPost && page.prev && sameLang(page.prev)) prevPost = page.prev;
        if (!nextPost && page.next && sameLang(page.next)) nextPost = page.next;
      %>
      <nav class="post-nav">
        <% if (prevPost) { %>
        <a href="<%= url_for(prevPost.path) %>" class="post-nav-item post-nav-prev">
          <span class="post-nav-label" data-i18n="post.previous">&larr; Previous</span>
          <span class="post-nav-title"><%= prevPost.title %></span>
        </a>
        <% } %>
        <% if (nextPost) { %>
        <a href="<%= url_for(nextPost.path) %>" class="post-nav-item post-nav-next">
          <span class="post-nav-label" data-i18n="post.next">Next &rarr;</span>
          <span class="post-nav-title"><%= nextPost.title %></span>
        </a>
        <% } %>
      </nav>
    </div>

    <!-- Table of Contents (right) -->
    <% if (theme.features.toc) { %>
    <aside class="toc-sidebar" id="toc-sidebar">
      <div class="toc-sidebar-inner">
        <h4 class="toc-title" data-i18n="post.toc">On This Page</h4>
        <%- toc(page.content, {max_depth: 4}) %>
      </div>
    </aside>
    <% } %>
  </div>
</article>

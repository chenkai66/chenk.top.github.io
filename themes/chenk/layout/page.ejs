<% if (page.type === 'series') { %>
<!-- Series Index Page -->
<div class="series-index-page">
  <h1 class="page-title">All Series</h1>
  <p class="page-subtitle"><%= Object.keys(theme.series || {}).length %> ongoing series covering ML, math, and CS</p>

  <% if (theme.series) { %>
    <% for (var key in theme.series) { var s = theme.series[key]; %>
      <%
        var catPosts = [];
        site.categories.forEach(function(cat) {
          if (cat.name === s.name) {
            cat.posts.each(function(p) { catPosts.push(p); });
          }
        });
        var published = catPosts.length;
        var progress = s.total > 0 ? Math.round((published / s.total) * 100) : 0;
      %>
      <a href="/categories/<%= s.name.replace(/ /g, '-') %>/" class="series-index-card">
        <div class="series-index-card-top">
          <span class="series-index-card-name"><%= s.name %></span>
          <span class="series-index-card-count"><%= published %> / <%= s.total %></span>
        </div>
        <p class="series-index-card-desc"><%= s.description %></p>
        <div class="series-index-progress">
          <div class="series-index-progress-bar">
            <div class="series-index-progress-fill" style="width: <%= progress %>%"></div>
          </div>
          <span class="series-index-progress-text"><%= progress %>%</span>
        </div>
      </a>
    <% } %>
  <% } %>
</div>

<% } else { %>
<!-- Generic Page -->
<div class="page-content">
  <h1 class="page-title"><%= page.title %></h1>
  <div class="markdown-body">
    <%- page.content %>
  </div>
</div>
<% } %>

<div class="home-page">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-inner">
      <span class="hero-eyebrow" data-i18n="home.eyebrow">Tech &middot; Mathematics &middot; Curiosity</span>
      <h1 class="hero-title" data-i18n="home.hero.title">Machine Learning, Mathematics &amp; Computer Science</h1>
      <p class="hero-subtitle" data-i18n="home.hero.subtitle">Deep technical content explained for humans. From first principles to production systems.</p>
      <div class="hero-stats">
        <span class="stat"><strong><%= site.posts.length %></strong><span class="stat-label" data-i18n="home.stats.articles">Articles</span></span>
        <span class="stat"><strong><%= Object.keys(theme.series || {}).length %></strong><span class="stat-label" data-i18n="home.stats.series">Series</span></span>
        <span class="stat"><strong>2</strong><span class="stat-label" data-i18n="home.stats.languages">Languages</span></span>
      </div>
    </div>
  </section>

  <!-- Featured Series -->
  <section class="series-grid">
    <h2 class="section-title" data-i18n="home.featured">Featured Series</h2>
    <div class="series-cards">
      <% if (theme.series) { %>
        <%
          var seriesKeys = Object.keys(theme.series);
          var featured = ['recommendation-systems', 'ml-math-derivations', 'linear-algebra'];
        %>
        <% seriesKeys.forEach(function(key, idx) { var s = theme.series[key]; %>
        <a href="/categories/<%= s.name.replace(/ /g, '-') %>/" class="series-card<%= featured.indexOf(key) !== -1 ? ' featured' : '' %>" data-category="<%= s.category || '' %>">
          <div class="series-card-content">
            <h3 class="series-card-title"><%= s.name %></h3>
            <p class="series-card-desc"><%= s.description %></p>
            <span class="series-card-meta"><%= s.total %> chapters</span>
          </div>
          <div class="series-card-number"><%= s.total %></div>
        </a>
        <% }); %>
      <% } %>
    </div>
  </section>

  <!-- Recent Posts -->
  <section class="recent-posts">
    <h2 class="section-title" data-i18n="home.recent">Recent Articles</h2>
    <div class="post-list">
      <% page.posts.each(function(post) { %>
      <article class="post-card" data-post-lang="<%= post.lang || 'en' %>">
        <div class="post-card-content">
          <div class="post-card-meta">
            <time datetime="<%= date(post.date, 'YYYY-MM-DD') %>"><%= date(post.date, 'MMM DD, YYYY') %></time>
            <% if (post.categories && post.categories.length) { %>
              <span class="post-card-category"><%= post.categories.data[0].name %></span>
            <% } %>
            <% if (post.lang) { %>
              <span class="post-card-lang" data-lang="<%= post.lang %>"><%= post.lang === 'zh-CN' ? 'CN' : 'EN' %></span>
            <% } %>
            <span class="post-card-reading-time">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              <% var pwc = post.content ? wordcount(post.content) : 0; %>
              <%= pwc > 0 ? Math.ceil(pwc / 250) + ' min' : '—' %>
            </span>
          </div>
          <h3 class="post-card-title">
            <a href="<%= url_for(post.path) %>"><%= post.title %></a>
          </h3>
          <p class="post-card-excerpt"><%= post.description || truncate(strip_html(post.content), {length: 160}) %></p>
          <% if (post.tags && post.tags.length) { %>
          <div class="post-card-tags">
            <% post.tags.each(function(tag) { %>
              <a href="<%= url_for(tag.path) %>" class="tag"><%= tag.name %></a>
            <% }) %>
          </div>
          <% } %>
        </div>
      </article>
      <% }) %>
    </div>

    <%- partial('_partial/pagination') %>
  </section>
</div>

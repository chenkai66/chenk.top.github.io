 &lt;img src="https://blog-pic-ck.oss-cn-beijing.aliyuncs.com/posts/zh/leetcode/04-%e6%bb%91%e5%8a%a8%e7%aa%97%e5%8f%a3%e6%8a%80%e5%b7%a7/illustration_1.png" alt="章节概念图" loading="lazy" decoding="async" class="content-image">
 
